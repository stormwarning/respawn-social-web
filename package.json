{
	"name": "respawn-social",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @respawn-social/web dev",
		"build": "pnpm -r build",
		"check": "pnpm -r check",
		"lint": "oxlint",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"test": "pnpm -r test",
		"test:e2e": "pnpm --filter @respawn-social/web test:e2e",
		"codegen": "pnpm --filter @respawn-social/web codegen"
	},
	"devDependencies": {
		"oxfmt": "0.55.0",
		"oxlint": "1.70.0"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"packageManager": "pnpm@10.28.2"
}
