# Postgres connection string (required).
DATABASE_URL=postgres://localhost:5432/respawn

# HTTP port for the read API.
PORT=8100

# Shared secret required in the x-appview-secret header.  Unset = open (dev).
APPVIEW_SECRET=

# Jetstream endpoint to consume.
JETSTREAM_URL=wss://jetstream2.us-west.bsky.network/subscribe

# Relay used by `pnpm sync` to enumerate repos per collection.
RELAY_URL=https://relay1.us-west.bsky.network

# Set to 0 to run the API without the Jetstream consumer.
INGEST=1
