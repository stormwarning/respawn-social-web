{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["ES2023"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022"
	},
	"include": ["src", "tests"]
}
