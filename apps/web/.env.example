# Public base URL of THIS app (used to build OAuth client_id + redirect_uri).
# Production: https://your-app.netlify.app  — Dev: leave unset (loopback client).
APP_URL=

# Base URL of the respawn-social-backend API service (IGDB games).
BACKEND_API_URL=http://localhost:8000

# Confidential-client signing key (ES256 private JWK, single-line JSON).
# Generate with: node scripts/gen-jwk.mjs   (see README)
PRIVATE_JWK=

# Secret used to sign the session cookie (random 32+ byte hex).
# Generate with: openssl rand -hex 32
COOKIE_SECRET=

# Base URL of the appview read API (services/appview). Leave unset to fall
# back to PDS-direct reads (no following feed).
APPVIEW_URL=http://localhost:8100

# Shared secret sent as x-appview-secret; must match the appview's env.
APPVIEW_SECRET=
